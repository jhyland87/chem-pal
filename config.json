{
  "defaultSettings": {
    "showHelp": false,
    "caching": true,
    "doNotCacheEmptyResults": true,
    "cacheTtlMinutes": 0,
    "trackPriceHistory": true,
    "priceHistoryMaxPoints": 0,
    "autocomplete": true,
    "currency": "USD",
    "location": "US",
    "language": "en-US",
    "currencyRate": 1.0,
    "fontSize": "medium",
    "openInTab": true,
    "autoHideEmptyColumns": true,
    "theme": "light",
    "showColumnFilters": true,
    "excludeNonShippingSuppliers": true,
    "hideRestrictedProducts": true,
    "disabledSuppliers": [],
    "hideColumns": [
      "description",
      "uom",
      "sds",
      "specs",
      "coa",
      "cas",
      "formula",
      "moleweight",
      "purity",
      "concentration"
    ],
    "columnFilterConfig": {}
  },
  "defaultResultsLimit": 5,
  "useStorageCompression": false,
  "hotkeys": [
    {
      "id": "showHotkeyHelp",
      "keys": "shift+?",
      "description": "Show this list of hotkeys",
      "group": "General"
    },
    {
      "id": "clearAndRetrySearch",
      "keys": "mod+shift+r",
      "description": "Clear cache, clear results, and re-run the current search",
      "group": "Search",
      "flash": "Cache cleared, search re-triggered"
    },
    {
      "id": "goToSearch",
      "keys": { "mac": "meta+s", "other": "ctrl+shift+s" },
      "description": "Go to the search panel",
      "group": "Navigation"
    },
    {
      "id": "openHistory",
      "keys": "mod+h",
      "description": "Open search history in the side drawer",
      "group": "Navigation",
      "flash": "Search history opened"
    },
    {
      "id": "focusGlobalFilter",
      "keys": "mod+f",
      "description": "Focus the global filter on the results panel",
      "group": "Results"
    },
    {
      "id": "toggleColumnFilters",
      "keys": "mod+shift+f",
      "description": "Toggle the column filters in the results table",
      "group": "Results"
    },
    {
      "id": "abortSearch",
      "keys": "mod+.",
      "description": "Abort the currently-running search",
      "group": "Search",
      "flash": "Search aborted"
    }
  ]
}
