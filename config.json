{
  "defaultSettings": {
    "showHelp": false,
    "caching": true,
    "doNotCacheEmptyResults": true,
    "cacheTtlMinutes": 0,
    "trackPriceHistory": true,
    "priceHistoryMaxPoints": 0,
    "currency": "USD",
    "location": "US",
    "language": "en-US",
    "currencyRate": 1.0,
    "fontSize": "medium",
    "openInTab": true,
    "autoHideEmptyColumns": true,
    "theme": "light",
    "excludeNonShippingSuppliers": true,
    "hideRestrictedProducts": true,
    "disabledSuppliers": [],
    "hideColumns": [
      "description",
      "uom",
      "sds",
      "specs",
      "coa",
      "cas",
      "formula",
      "moleweight",
      "purity",
      "concentration"
    ]
  },
  "defaultResultsLimit": 5,
  "descriptionPreviewLength": 300,
  "maxSupplierCacheEntries": 100,
  "maxHistoryEntries": 100,
  "maxExportEntries": 20,
  "maxExportsCacheBytes": 26214400,
  "useStorageCompression": false,
  "sequenceResetMs": 1500,
  "hotkeys": [
    {
      "id": "showHotkeyHelp",
      "keys": "shift+?",
      "description": "Show this list of hotkeys",
      "group": "General"
    },
    {
      "id": "clearAndRetrySearch",
      "keys": "mod+shift+r",
      "description": "Clear cache, clear results, and re-run the current search",
      "group": "Search",
      "flash": "Cache cleared, search re-triggered"
    },
    {
      "id": "goToSearch",
      "keys": { "mac": "meta+s", "other": "ctrl+shift+s" },
      "description": "Go to the search panel",
      "group": "Navigation"
    },
    {
      "id": "openHistory",
      "keys": "mod+h",
      "description": "Open search history in the side drawer",
      "group": "Navigation",
      "flash": "Search history opened"
    },
    {
      "id": "openSearchDrawer",
      "keys": "alt+s",
      "description": "Open the search filters drawer",
      "group": "Navigation",
      "flash": "Search filters opened"
    },
    {
      "id": "focusGlobalFilter",
      "keys": "mod+f",
      "description": "Focus the global filter on the results panel",
      "group": "Results"
    },
    {
      "id": "toggleColumnFilters",
      "keys": "mod+shift+f",
      "description": "Toggle the column filters in the results table",
      "group": "Results"
    },
    {
      "id": "abortSearch",
      "keys": "mod+.",
      "description": "Abort the currently-running search",
      "group": "Search",
      "flash": "Search aborted"
    },
    {
      "id": "expandAllRows",
      "keys": "mod+shift+e",
      "description": "Expand all rows in the results table",
      "group": "Results",
      "flash": "All rows expanded"
    },
    {
      "id": "collapseAllRows",
      "keys": "mod+shift+c",
      "description": "Collapse all rows in the results table",
      "group": "Results",
      "flash": "All rows collapsed"
    },
    {
      "id": "scrollResultsToTop",
      "keys": "mod+shift+up",
      "description": "Scroll the results table to the top",
      "group": "Results"
    },
    {
      "id": "showAllRows",
      "keys": "mod+shift+a",
      "description": "Show all rows on one page (no pagination)",
      "group": "Results",
      "flash": "Showing all rows"
    },
    {
      "id": "clearColumnFilters",
      "keys": "mod+shift+backspace",
      "description": "Clear all column filters in the results table",
      "group": "Results",
      "flash": "Column filters cleared"
    },
    {
      "id": "konami",
      "keys": "upArrow+upArrow+downArrow+downArrow+leftArrow+rightArrow",
      "description": "Toggle advanced settings",
      "group": "General",
      "sequential": true,
      "unlisted": true
    }
  ]
}
