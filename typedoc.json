{
  "name": "ChemPal Documentation",
  "entryPoints": [
    "./src/**/index.ts",
    "./src/suppliers/*.ts",
    "./src/helpers/*.ts",
    "./src/constants/*.ts",
    "./src/types/*.ts",
    "./src/mixins/*.ts",
    "./src/components/**/*.tsx"
  ],
  "plugin": [
    "typedoc-plugin-mark-react-functional-components",
    "typedoc-plugin-expand-object-like-types",
    //"typedoc-theme-category-nav",
    //"typedoc-theme-hierarchy",
    "typedoc-plugin-rename-defaults",
    "typedoc-plugin-coverage",
    "typedoc-plugin-include-example",
    "typedoc-plugin-dt-links",
    "typedoc-plugin-mdn-links",
    "typedoc-plugin-missing-exports",
    "typedoc-plugin-not-exported",
    "typedoc-plugin-inline-sources",
    //"typedoc-theme-oxide",
    //"typedoc-unhoax-theme",,
    //"typedoc-plugin-mermaid",
    "./plugins/typedoc-mermaid-plugin.mjs",
    "typedoc-theme-hierarchy"
  ],
  "ignoredHighlightLanguages": [
    "mermaid"
  ],
  "logLevel": "Info",
  "theme": "hierarchy",
  "entryPointStrategy": "expand",
  "reactReturnType": [
    "ReactElement",
    "JSX.Element",
    "Element",
    "React.ReactElement"
  ],
  "markdownItOptions": {
    "html": true,
    "linkify": true
  },
  "projectDocuments": [
    "./pages/**/*.md"
  ],
  //"includes": "./pages/diagrams",
  "lightHighlightTheme": "github-light-high-contrast",
  "darkHighlightTheme": "github-dark-dimmed",
  "collapseInternalModule": true,
  "additionalModuleSources": [],
  "warnOnUnstableDtLink": false,
  "cleanOutputDir": true,
  "pretty": true,
  "groupReferencesByType": true,
  "alwaysCreateEntryPointModule": true,
  "searchCategoryBoosts": {
    "Components": 3.3,
    "Helpers": 2.2,
    "Suppliers": 0.1
  },
  "searchGroupBoosts": {
    "Modules": 5.0,
    "Classes": 4.0,
    "Interfaces": 3.0,
    "Functions": 2.0
  },
  "jsDocCompatibility": true,
  "placeInternalsInOwningModule": false,
  "useTsLinkResolution": true,
  "out": "docs",
  "exclude": [
    "**/vite-env*",
    "**/node_modules/**",
    "**/__tests__/**",
    "**/__mocks__/**"
  ],
  "useFirstParagraphOfCommentAsSummary": true,
  "includeHierarchySummary": true,
  "navigation": {
    "includeFolders": true,
    "compactFolders": true,
    "includeGroups": true,
    "includeCategories": true,
    "excludeReferences": true
  },
  "searchInDocuments": true,
  "searchInComments": true,
  "excludeTags": [
    //"@internal",
    "@private",
    "@protected"
  ],
  "includeVersion": true,
  "hideGenerator": false,
  "readme": "README.md",
  "navigationLinks": {
    "Reference": "https://jhyland87.github.io/chem-pal",
    "GitHub": "https://github.com/jhyland87/chem-pal",
    "Wiki": "https://github.com/jhyland87/chem-pal/wiki"
  },
  "sort": [
    "source-order"
  ],
  "excludeReferences": false,
  "excludeProtected": false,
  "excludePrivate": false,
  "excludeNotDocumented": false,
  "excludeInternal": true,
  "resolveUtilityTypes": true,
  "externalPattern": [
    "**/node_modules/**"
  ],
  "excludeExternals": true,
  "visibilityFilters": {
    "protected": true,
    "private": true,
    "inherited": false,
    "external": false
  },
  "sourceLinkTemplate": "https://github.com/jhyland87/chem-pal/blob/main/{path}#L{line}",
  "disableSources": false,
  "categorizeByGroup": true,
  "defaultCategory": "Suppliers",
  "categoryOrder": [
    "Suppliers",
    "Components",
    "Utils",
    "Hooks",
    "Types",
    "Typeguards",
    "Helpers",
    "Context",
    "*"
  ],
  "groupOrder": [
    "Diagrams",
    "Documents",
    "Logging",
    "Utils",
    "Components",
    "Hooks",
    "Types",
    "Typeguards",
    "*"
  ],
  "options": "./typedoc-conf.js"
}