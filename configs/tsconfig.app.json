{
  "compilerOptions": {
    "tsBuildInfoFile": "../node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2024",
    "strictNullChecks": true,
    "useDefineForClassFields": true,
    "resolveJsonModule": true,
    "allowUmdGlobalAccess": true,
    "esModuleInterop": true,
    "lib": [
      "ES2024",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "skipLibCheck": true,
    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "experimentalDecorators": true,
    "jsx": "react-jsx",
    // No `baseUrl` (deprecated in TS 7): `paths` entries resolve relative to
    // this config file's directory.
    "paths": {
      "@/*": [
        "../src/*"
      ],
      // country-list-js@3.1.8 ships an inadequate index.d.ts (`all: {}`) that
      // shadows @types/country-list-js. Point type resolution at the @types
      // declarations instead; runtime resolution (Vite) still uses the real JS.
      "country-list-js": [
        "../node_modules/@types/country-list-js/index.d.ts"
      ],
    },
    /* Linting */
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "forceConsistentCasingInFileNames": true,
    "typeRoots": [
      "../node_modules/@types",
      "../src/types/**/*"
    ],
    "types": [
      "node",
      "chrome"
    ]
  },
  "include": [
    "../src"
  ],
  "exclude": [
    "**/__tests__/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx"
  ]
}