{
  "manifest_version": 3,
  "name": "ChemPal",
  "version": "0.0.0",
  "description": "Chemical reagent search utility for hobby chemists",
  "action": {
    "default_popup": "index.html"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "permissions": ["scripting", "sidePanel", "tabs", "activeTab", "storage", "nativeMessaging"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "icons": {
    "32": "static/images/logo/Cp6.png",
    "48": "static/images/logo/Cp6.png",
    "128": "static/images/logo/Cp6.png"
  }
}
