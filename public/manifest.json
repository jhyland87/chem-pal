{
  "manifest_version": 3,
  "name": "Chem Pal",
  "version": "0.0.12",
  "description": "A simple React app as a Chrome extension",
  "action": {
    "default_popup": "index.html"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "permissions": [
    "scripting",
    "sidePanel",
    "tabs",
    "storage",
    "bookmarks",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "https://www.ambeed.com/*",
    "https://www.carolina.com/*",
    "https://carolinachemical.com/*",
    "https://www.chemsavers.com/*",
    "https://0ul35zwtpkx14ifhp-1.a1.typesense.net/*",
    "https://www.biofuranchem.com/*",
    "https://www.ftfscientific.com/*",
    "https://www.hbarsci.com/*",
    "https://www.laballey.com/*",
    "https://searchserverapi.com/*",
    "https://www.laboratoriumdiscounter.nl/*",
    "https://libertysci.com/*",
    "https://www.loudwolf.com/*",
    "https://www.macklin.cn/*",
    "https://api.macklin.cn/*",
    "https://onyxmet.com/*",
    "https://synthetikaeu.com/*",
    "https://warchem.pl/*",
    "https://www.amazon.com/*",
    "https://www.amazon.co.uk/*",
    "https://www.amazon.de/*",
    "https://www.amazon.co.jp/*",
    "https://www.amazon.ca/*",
    "https://www.amazon.fr/*",
    "https://www.amazon.com.au/*",
    "https://www.amazon.cn/*",
    "https://www.amazon.es/*",
    "https://www.amazon.it/*",
    "https://www.amazon.in/*",
    "https://www.amazon.nl/*",
    "https://www.amazon.pl/*",
    "https://www.amazon.pt/*",
    "https://www.amazon.se/*",
    "https://www.amazon.com.sg/*",
    "https://www.amazon.com.mx/*",
    "https://www.amazon.ae/*",
    "https://www.amazon.com.br/*",
    "https://www.amazon.com.tr/*",
    "https://www.amazon.sa/*",
    "https://www.amazon.com.ar/*",
    "https://www.amazon.com.be/*",
    "https://www.amazon.eg/*",
    "https://www.amazon.ie/*",
    "https://www.amazon.co.za/*",
    "https://gold-testing-equipment.myshopify.com/*",
    "https://www.goldandsilvertesting.com/*",
    "https://pubchem.ncbi.nlm.nih.gov/*",
    "https://best-value-vacs.myshopify.com/*",
    "https://shopbvv.com/*",
    "https://alchemielabs.com/*",
    "https://aladdinsci.com/*",
    "https://www.amazon.com/*",
    "https://www.amazon.co.uk/*",
    "https://www.amazon.de/*",
    "https://www.amazon.co.jp/*",
    "https://www.amazon.ca/*",
    "https://alchemielabs.com/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "icons": {
    "32": "static/images/logo/ChemPal-logo-v2-inverted.png",
    "48": "static/images/logo/ChemPal-logo-v2-inverted.png",
    "128": "static/images/logo/ChemPal-logo-v2-inverted.png"
  }
}
