  "sourceType": "module",
  "scripts": {
    "prebuild": "pnpm run generate-logo-files",
    "dev": "pnpm run generate-logo-files && vite",
    "dev-mock": "vite --mode=mock",
    "type-check": "tsc -b",
    "build": "vite build --mode=development",
    "build:firefox": "BROWSER=firefox vite build --mode=development",
    "build:aggregate": "vite build --mode=aggregate",
    "build:full": "pnpm type-check && pnpm build",
    "lint": "eslint src --ignore-pattern '**/__tests__/**' --ignore-pattern '**/__fixtures__/**' --ignore-pattern '**/__mocks__/**' --ignore-pattern '**/*.test.*' --ignore-pattern '**/*.spec.*' --ignore-pattern '**/*[Mm]ock*'",
    "preview": "vite preview",
    "demo": "pnpm run generate-logo-files && vite build --mode=production && playwright test --config configs/playwright.demo.config.ts",
    "test": "vitest run --config configs/vitest.config.ts",
    "test:full": "pnpm run lint && pnpm run test:all && pnpm run docs",
    "test:all": "pnpm test && pnpm test:e2e",
    "test:ui": "vitest --ui --coverage --open=true --config configs/vitest.config.ts",
    "test:ui:open": "vitest --ui --coverage --open=true --config configs/vitest.config.ts",
    "test:coverage": "vitest run --coverage --open=true --config configs/vitest.config.ts",
    "test:run": "vitest run --config configs/vitest.config.ts",
    "test:e2e": "pnpm run test:e2e:chrome && pnpm run test:e2e:firefox",
    "test:e2e:chrome": "vitest run --config configs/vitest.e2e.config.ts",
    "test:e2e:firefox": "vitest run --config configs/vitest.e2e.firefox.config.ts",
    "lint:firefox": "web-ext lint --source-dir build-firefox",
    "docs": "typedoc --options configs/typedoc.json && cp themes/typedoc-theme-hierarchy/packages/plugin/dist/assets/hierarchy.css themes/typedoc-theme-hierarchy/packages/plugin/dist/assets/hierarchy-theme.js docs/assets/ && cp privacy.html docs/privacy.html",
    "docs:www": "pnpm run docs && npx http-server -p 8080 docs",
    "validate-docs": "tsc --noEmit",
    "generate-logo-files": "node tools/generate-logo-files.js",
    "pack": "node tools/pack-extension.js",
    "build:prod": "pnpm run generate-logo-files && vite build --mode=production && node tools/pack-extension.js",
    "build:prod:firefox": "pnpm run generate-logo-files && BROWSER=firefox vite build --mode=production && node tools/pack-firefox.js",
    "show-deprecations": "pnpm outdated --json | jq '.[] | select(.isDeprecated)'"
  },
