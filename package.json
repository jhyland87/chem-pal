  "scripts": {
    "prebuild": "pnpm run generate-logo-files",
    "dev": "pnpm run generate-logo-files && vite",
    "dev-mock": "vite --mode=mock",
    "type-check": "tsc --noEmit",
    "build": "vite build --mode=development",
    "build:aggregate": "vite build --mode=aggregate",
    "build:full": "pnpm type-check && pnpm build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui --coverage --open=true",
    "test:ui:open": "vitest --ui --coverage --open=true",
    "test:coverage": "vitest run --coverage --open=true",
    "test:run": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "docs": "typedoc --options typedoc.json && cp themes/typedoc-theme-hierarchy/packages/plugin/dist/assets/hierarchy.css themes/typedoc-theme-hierarchy/packages/plugin/dist/assets/hierarchy-theme.js docs/assets/",
    "docs:www": "npx http-server -p 8080 docs",
    "validate-docs": "tsc --noEmit",
    "generate-logo-files": "node tools/generate-logo-files.js"
  },
